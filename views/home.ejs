                    </a>
                </li>

            </ul>

        </div>

    </div>
</nav>

<section class="hero">

    <div class="container text-center">

        <h1 class="display-3 fw-bold text-success">
            Empowering Students Through Education
        </h1>

        <p class="lead mt-4">
            Join NayePankh Foundation in creating opportunities,
            spreading awareness, and supporting students through
            scholarships and community initiatives.
        </p>

        <a href="/register"
           class="btn btn-success btn-lg mt-3">

            Become a Volunteer

        </a>

    </div>

</section>

<div class="container mt-5">

    <div class="row g-4">

        <div class="col-md-4">

            <div class="card shadow text-center p-4">

                <h1 class="text-success">
                    5000+
                </h1>

                <h5>
                    Students Supported
                </h5>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow text-center p-4">

                <h1 class="text-primary">
                    1000+
                </h1>

                <h5>
                    Volunteers
                </h5>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card shadow text-center p-4">

                <h1 class="text-warning">
                    50+
                </h1>

                <h5>
                    Campaigns Conducted
                </h5>

            </div>

        </div>

    </div>

</div>
