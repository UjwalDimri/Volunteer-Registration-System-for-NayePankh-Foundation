<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Database</title>
</head>
<body>
<form action="/edit/<%= volunteer.id %>?_method=PUT"
      method="POST">

    <input
    type="text"
    name="name"
    value="<%= volunteer.name %>">

    <input
    type="email"
    name="email"
    value="<%= volunteer.email %>">

    <input
    type="text"
    name="phone"
    value="<%= volunteer.phone %>">

    <input
    type="text"
    name="college"
    value="<%= volunteer.college %>">

    <input
    type="text"
    name="skills"
    value="<%= volunteer.skills %>">

    <input
    type="text"
    name="interest"
    value="<%= volunteer.interest %>">

    <button>

        Update

    </button>

</form>

</body>
</html>